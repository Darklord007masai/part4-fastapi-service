        "import pickle\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "\n",
        "def train_and_save_mock_model():\n",
        "    print(\"Training baseline Churn Model...\")\n",
        "\n",
        "    # Simulating 100 customers with 4 vital features:\n",
        "    # tenure_months, support_tickets, monthly_charges, monthly_active_days\n",
        "    np.random.seed(42)\n",
        "    X = np.random.rand(100, 4)\n",
        "    X[:, 1] = np.random.randint(0, 10, size=100) # Support tickets\n",
        "    X[:, 3] = np.random.randint(0, 30, size=100) # Active days\n",
        "\n",
        "    # Binary labels (0: Retained, 1: Churned)\n",
        "    y = np.random.choice([0, 1], size=100, p=[0.7, 0.3])\n",
        "\n",
        "    model = LogisticRegression()\n",
        "    model.fit(X, y)\n",
        "\n",
        "    with open(\"model.pkl\", \"wb\") as f:\n",
        "        pickle.dump(model, f)\n",
        "    print(\"Model successfully saved to model.pkl\")\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    train_and_save_mock_model()"
      ],
